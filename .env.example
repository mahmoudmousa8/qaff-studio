# ── Database ──────────────────────────────────────────────────
DATABASE_URL=file:./data/app.db

# ── Data Directories (relative to project root) ──────────────
APP_DATA_DIR=./data
VIDEOS_DIR=./data/videos
UPLOAD_DIR=./data/upload
DOWNLOAD_DIR=./data/download
LOGS_DIR=./data/logs

# ── Stream Manager ────────────────────────────────────────────
STREAM_MANAGER_URL=http://127.0.0.1:3002
STREAM_MANAGER_PORT=3002
MAX_CONCURRENT_STREAMS=10
STAGGER_MS=1000

# ── Web Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Auth ──────────────────────────────────────────────────────
# SESSION_SECRET is auto-generated by install.sh — do not set manually unless you know what you're doing
SESSION_SECRET=change-me-to-a-random-secure-string
